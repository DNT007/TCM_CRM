# Cấu hình Server
PORT=3005

# Cấu hình SQL Server
# Windows Authentication: để trống DB_USER và DB_PASSWORD
# SQL Server Authentication: điền đầy đủ
DB_SERVER=localhost
DB_USER=sa
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_NAME=TCT_CRM

# API Authentication Key (bắt buộc đổi thành key bảo mật khi production)
API_KEY=CHANGE_ME_TO_A_STRONG_SECRET_KEY

# ─── Production: URL công khai của API (quan trọng khi dùng HTTPS) ────────────
# Nếu Swagger UI được serve qua HTTPS, PHẢI set biến này thành URL HTTPS của API
# để tránh lỗi "Mixed Content" (HTTPS page gọi HTTP API bị browser chặn).
#
# Ví dụ nếu có domain:  API_BASE_URL=https://api.tecotec.vn
# Ví dụ nếu dùng IP+SSL: API_BASE_URL=https://65.124.94.224
# Nếu chỉ chạy local/LAN (HTTP): để trống dòng này
API_BASE_URL=
